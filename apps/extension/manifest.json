{
  "manifest_version": 3,
  "name": "civilium bridge",
  "short_name": "civilium",
  "version": "3.0.2",
  "description": "Conecta o civilium ao portal da Receita Federal para consultas cadastrais com resolução manual de CAPTCHA.",
  "homepage_url": "https://civiliumpro.vercel.app",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://servicos.receita.fazenda.gov.br/*",
    "https://civiliumpro.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "civilium bridge — Configuração",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://civiliumpro.vercel.app/*",
        "http://localhost:3000/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://servicos.receita.fazenda.gov.br/*"],
      "js": ["content_script.js"],
      "run_at": "document_start"
    }
  ]
}
