{
  "name": "civiliumpro",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @civilium/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:push": "pnpm --filter @civilium/web db:push",
    "setup:secrets": "node scripts/setup-secrets.mjs",
    "icons:extension": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/extract-ico.ps1 && node scripts/generate-extension-icons.mjs",
    "pack:extension": "node scripts/pack-extension.mjs",
    "pack:store": "node scripts/pack-store.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "sharp": "^0.34.5"
  }
}
