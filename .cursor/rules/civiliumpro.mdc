## Formulários

SEMPRE **React Hook Form + Zod + shadcn/ui Form**.

```typescript
"use server";

import { z } from "zod";
import { actionClient } from "@/lib/safe-action";

const iniciarLoteSchema = z.object({
  nomeArquivo: z.string().min(1),
  pessoas: z.array(z.object({
    nomeInformado: z.string().min(1),
    cpf: z.string().regex(/^\d{11}$/, "CPF deve ter 11 dígitos"),
    dataNascimento: z.string().regex(/^\d{2}\/\d{2}\/\d{4}$/),
  })).min(1).max(100),
});

export const iniciarLote = actionClient
  .schema(iniciarLoteSchema)
  .action(async ({ parsedInput }) => {
    // implementação
  });
```

